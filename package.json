{
  "name": "mugenblock",
  "private": true,
  "workspaces": [
    "shared",
    "extension"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=extension",
    "build": "npm run build --workspace=shared && npm run build --workspace=extension",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "check": "tsc --build"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "prettier": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0"
  }
}
